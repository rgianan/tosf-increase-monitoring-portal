# Apps Script Web App URL after deployment.
VITE_GAS_WEB_APP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Optional. If set here, set the exact same SUBMIT_SHARED_TOKEN in Apps Script Properties.
# This ships in the browser, so treat it only as a low-friction gate, not a real secret.
VITE_SUBMIT_SHARED_TOKEN=replace_with_same_value_as_apps_script_submit_shared_token

# Optional email domain restriction hint for the public OTP form. Leave blank to
# allow any email domain. Set the same value as ALLOWED_EMAIL_DOMAIN in Apps Script, where
# the restriction is enforced.
VITE_ALLOWED_EMAIL_DOMAIN=ched.gov.ph
