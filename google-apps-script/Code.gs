function submissionToRow_(headers, data) {
  var row = data.row;
  var map = {
    Timestamp: formatDateTime_(data.timestamp),
    Submission_ID: data.submissionId,
    Region_Code: row.regionCode,
    Region_Label: row.regionLabel,
    RIR: row.rir,
    UII: row.uii,
    HEI_Name: row.heiName,
    Province: row.province,
    City_Municipality: row.cityMunicipality,
    HEI_Status: row.heiStatus,
    Proposed_TF_Increase: row.proposedTfIncrease,
    Proposed_OSF_Increase: row.proposedOsfIncrease,
    RIR_Category: row.rirCategory,
    Action_Status: row.actionStatus,
    Other_Specifics: row.otherSpecifics,
    Remarks: row.remarks,
    Submitted_By_Name: row.submittedByName,
    Submitted_By_Email: row.submittedByEmail,
    Submitted_By_Position: row.submittedByPosition,
    Submitted_By_Contact: row.submittedByContact,
    Updated_At: formatDateTime_(data.updatedAt),
    Updated_By: data.updatedBy,
    Source_User_Agent: data.userAgent,
    Client_Origin: data.clientOrigin,
    Voided: '',
    Voided_At: ''
  };
  return headers.map(function (header) { return map[header] !== undefined ? map[header] : ''; });
}

function submissionObjectToPayload_(obj) {
  return {
    timestamp: formatDateTime_(obj.Timestamp),
    submissionId: String(obj.Submission_ID || ''),
    regionCode: String(obj.Region_Code || ''),
    regionLabel: String(obj.Region_Label || ''),
    rir: numberOrBlank_(obj.RIR),
    uii: String(obj.UII || ''),
    heiName: String(obj.HEI_Name || ''),
    province: String(obj.Province || ''),
    cityMunicipality: String(obj.City_Municipality || ''),
    heiStatus: String(obj.HEI_Status || ''),
    proposedTfIncrease: numberOrNull_(obj.Proposed_TF_Increase),
    proposedOsfIncrease: numberOrNull_(obj.Proposed_OSF_Increase),
    rirCategory: String(obj.RIR_Category || ''),
    actionStatus: String(obj.Action_Status || ''),
    otherSpecifics: String(obj.Other_Specifics || ''),
    remarks: String(obj.Remarks || ''),
    submittedByName: String(obj.Submitted_By_Name || ''),
    submittedByEmail: String(obj.Submitted_By_Email || ''),
    submittedByPosition: String(obj.Submitted_By_Position || ''),
    submittedByContact: String(obj.Submitted_By_Contact || ''),
    updatedAt: formatDateTime_(obj.Updated_At),
    updatedBy: String(obj.Updated_By || ''),
    voided: isTruthyFlag_(obj.Voided),
    voidedAt: formatDateTime_(obj.Voided_At)
  };
}

function buildSummary_(rows) {
  var summary = {
    total: rows.length,
    rirCategories: {},
    actionStatuses: {},
    regions: {}
  };
  REGION_META.forEach(function (region) {
    summary.regions[region.code] = { total: 0, label: region.label, rir: region.rir };
  });
  rows.forEach(function (row) {
    increment_(summary.rirCategories, row.rirCategory || 'Blank');
    increment_(summary.actionStatuses, row.actionStatus || 'Blank');
    if (!summary.regions[row.regionCode]) summary.regions[row.regionCode] = { total: 0, label: row.regionLabel || row.regionCode };
    summary.regions[row.regionCode].total += 1;
  });
  summary.decreasedTotal = (summary.actionStatuses['Decrease: within RIR'] || 0) + (summary.actionStatuses['Decrease: from above RIR to within RIR'] || 0);
  return summary;
}

function increment_(obj, key) {
  obj[key] = (obj[key] || 0) + 1;
}

function getSubmissionsSheet_(config) {
  var sheet = getOrCreateSheet_(config.submissionsSheetName);
  ensureHeaders_(sheet, getSubmissionHeaders_());
  return sheet;
}

function getUsersSheet_() {
  var sheet = getOrCreateSheet_(getConfig_().usersSheetName);
  ensureHeaders_(sheet, getUserHeaders_());
  return sheet;
}

function getUserHeaders_() {
  return ['Email', 'Password_Record', 'Display_Name', 'Role', 'Active', 'Created_At', 'Last_Login'];
}

function getAuditSheet_() {
  var sheet = getOrCreateSheet_(getConfig_().auditSheetName);
  ensureHeaders_(sheet, ['Timestamp', 'Action', 'Status', 'Reference', 'Email', 'Detail']);
  return sheet;
}

function getOrCreateSheet_(name) {
  var ss = openSpreadsheet_(getConfig_());
  var sheet = ss.getSheetByName(name);
  if (!sheet) sheet = ss.insertSheet(name);
  return sheet;
}

function ensureHeaders_(sheet, headers) {
  var existing = sheet.getLastColumn() ? sheet.getRange(1, 1, 1, Math.max(sheet.getLastColumn(), headers.length)).getValues()[0] : [];
  var needsUpdate = false;
  for (var i = 0; i < headers.length; i++) {
    if (String(existing[i] || '') !== headers[i]) {
      needsUpdate = true;
      break;
    }
  }
  if (needsUpdate) {
    sheet.getRange(1, 1, 1, headers.length).setValues([headers]);
    sheet.setFrozenRows(1);
  }
}

function makeUniqueSubmissionIdFromSet_(existing) {
  var id;
  do {
    id = SUBMISSION_ID_PREFIX + '-' + Utilities.formatDate(new Date(), APP_TIME_ZONE, 'yyyyMMdd') + '-' + randomString_(6);
  } while (existing[id]);
  existing[id] = true;
  return id;
}

function readSubmissionIdSet_(sheet) {
  var out = {};
  if (sheet.getLastRow() < 2) return out;
  var headers = sheet.getRange(1, 1, 1, sheet.getLastColumn()).getValues()[0];
  var map = columnMap_(headers);
  var col = map.Submission_ID;
  if (col === undefined) return out;
  var values = sheet.getRange(2, col + 1, sheet.getLastRow() - 1, 1).getValues();
  values.forEach(function (row) {
    var value = String(row[0] || '').trim();
    if (value) out[value] = true;
  });
  return out;
}

function randomString_(length) {
  var chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
  var out = '';
  for (var i = 0; i < length; i++) out += chars.charAt(Math.floor(Math.random() * chars.length));
  return out;
}

function computeRirCategory_(tfIncrease, osfIncrease, rir) {
  var values = [];
  if (tfIncrease !== null && tfIncrease !== undefined && tfIncrease !== '') values.push(Number(tfIncrease));
  if (osfIncrease !== null && osfIncrease !== undefined && osfIncrease !== '') values.push(Number(osfIncrease));
  if (!values.length) return '';
  var highest = Math.max.apply(null, values);
  var tolerance = 0.0001;
  if (highest > Number(rir) + tolerance) return 'Higher than the RIR';
  if (Math.abs(highest - Number(rir)) <= tolerance) return 'Equivalent to the applicable RIR';
  return 'Below the applicable RIR';
}

function getRegionByCode_(code) {
  code = normalizeRegionCode_(code);
  for (var i = 0; i < REGION_META.length; i++) {
    if (REGION_META[i].code === code) return REGION_META[i];
  }
  return null;
}

function normalizeRegionCode_(value) {
  var text = cleanText_(value, 20);
  return text.replace(/^0+/, '') || text;
}

function nullableNumber_(value, label) {
  if (value === '' || value === null || value === undefined) return null;
  var num = Number(String(value).replace(/,/g, '').trim());
  if (!isFinite(num)) throw new Error(label + ' must be numeric.');
  return num;
}

function numberOrNull_(value) {
  if (value === '' || value === null || value === undefined) return null;
  var num = Number(value);
  return isFinite(num) ? num : null;
}

function numberOrBlank_(value) {
  var num = numberOrNull_(value);
  return num === null ? '' : num;
}

function requireAdmin_(payload) {
  var session = verifyAdminToken_(payload && payload.adminToken);
  if (!session) throw new Error('Admin session expired. Please sign in again.');
  return session;
}

// Reads the Users sheet once and returns the matching row with enough context
// ({ user, rowIndex (1-based), map, sheet }) for in-place updates, so the
// login path does not re-read the sheet to touch Last_Login or upgrade the
// password record.
function findUserRecord_(email) {
  var sheet = getUsersSheet_();
  var values = sheet.getDataRange().getValues();
  if (values.length < 2) return null;
  var headers = values[0];
  var map = columnMap_(headers);
  for (var i = 1; i < values.length; i++) {
    var obj = rowToObject_(headers, values[i]);
    if (normalizeEmail_(obj.Email) === email) return { user: obj, rowIndex: i + 1, map: map, sheet: sheet };
  }
  return null;
}

function issueAdminToken_(user) {
  var now = Math.floor(Date.now() / 1000);
  var body = {
    email: normalizeEmail_(user.Email),
    role: String(user.Role || 'admin'),
    exp: now + SESSION_TTL_SECONDS,
    iat: now
  };
  var bodyEncoded = base64UrlEncode_(JSON.stringify(body));
  var sig = sign_(bodyEncoded);
  return bodyEncoded + '.' + sig;
}

function verifyAdminToken_(token) {
  token = String(token || '');
  var parts = token.split('.');
  if (parts.length !== 2) return null;
  if (!constantTimeEquals_(sign_(parts[0]), parts[1])) return null;
  var body;
  try {
    body = JSON.parse(base64UrlDecode_(parts[0]));
  } catch (err) {
    return null;
  }
  if (!body.exp || Number(body.exp) < Math.floor(Date.now() / 1000)) return null;
  return body;
}

function sign_(value) {
  var secret = getSessionSecret_();
  var signature = Utilities.computeHmacSha256Signature(String(value), secret);
  return base64UrlEncodeBytes_(signature);
}

function getSessionSecret_() {
  var props = getProps_();
  if (!props.SESSION_SECRET) {
    props.SESSION_SECRET = Utilities.getUuid() + ':' + Utilities.getUuid();
    PropertiesService.getScriptProperties().setProperty('SESSION_SECRET', props.SESSION_SECRET);
  }
  return props.SESSION_SECRET;
}

// Server-side pepper for v3 password records. Stored in Script Properties, so
// an attacker who can read the Users sheet (but not the properties) cannot
// brute-force password hashes at all. Note: anyone who CAN read the properties
// already holds SESSION_SECRET and can mint admin tokens directly, so extra
// hash iterations add no protection in that scenario - which is why v3 uses a
// single peppered HMAC instead of thousands of iterations.
function getPasswordPepper_() {
  var props = getProps_();
  if (!props.PASSWORD_PEPPER) {
    props.PASSWORD_PEPPER = Utilities.getUuid() + ':' + Utilities.getUuid();
    PropertiesService.getScriptProperties().setProperty('PASSWORD_PEPPER', props.PASSWORD_PEPPER);
  }
  return props.PASSWORD_PEPPER;
}

// Legacy v1 hashing: re-encodes to base64 each round (two Utilities calls per
// iteration). Kept only so existing v1 records still verify.
function hashPassword_(password, salt, iterations) {
  var bytes = Utilities.computeHmacSha256Signature(String(password), salt);
  for (var i = 1; i < iterations; i++) {
    bytes = Utilities.computeHmacSha256Signature(bytesToBase64_(bytes), salt);
  }
  return bytesToBase64_(bytes);
}

// v2 hashing: iterate on raw bytes (one HMAC call per iteration, no base64),
// roughly halving the work versus v1 for the same iteration count.
function hashPasswordFast_(password, salt, iterations) {
  var saltBytes = Utilities.newBlob(String(salt)).getBytes();
  var bytes = Utilities.computeHmacSha256Signature(String(password), String(salt));
  for (var i = 1; i < iterations; i++) {
    bytes = Utilities.computeHmacSha256Signature(bytes, saltBytes);
  }
  return Utilities.base64Encode(bytes);
}

// v3 hashing: a single HMAC keyed by the server-side pepper. One Utilities
// call, so verification is effectively instant. See getPasswordPepper_ for the
// threat-model rationale.
function hashPasswordPeppered_(password, salt) {
  var bytes = Utilities.computeHmacSha256Signature(String(salt) + ':' + String(password), getPasswordPepper_());
  return Utilities.base64Encode(bytes);
}

function makePasswordRecord_(password) {
  var salt = Utilities.getUuid() + Utilities.getUuid();
  return ['v3', 1, salt, hashPasswordPeppered_(password, salt)].join('$');
}

function verifyPassword_(password, record) {
  var parts = String(record || '').split('$');
  if (parts.length !== 4) return false;
  var version = parts[0];
  var iterations = Number(parts[1]);
  var salt = parts[2];
  var expected = parts[3];
  if (!iterations || iterations < 1) return false;

  var actual;
  if (version === 'v3') actual = hashPasswordPeppered_(password, salt);
  else if (version === 'v2') actual = hashPasswordFast_(password, salt, iterations);
  else if (version === 'v1') actual = hashPassword_(password, salt, iterations);
  else return false;

  return constantTimeEquals_(actual, expected);
}

function isLegacyPasswordRecord_(record) {
  return /^v[12]\$/.test(String(record || ''));
}

function seedUser(email, password, displayName, role) {
  email = normalizeEmail_(email);
  password = String(password === null || password === undefined ? '' : password);
  displayName = cleanText_(displayName || email, 180);
  role = cleanText_(role || 'admin', 80);
  if (!email || !password) throw new Error('Email and password are required.');

  var sheet = getUsersSheet_();
  var headers = getUserHeaders_();
  var headerWidth = Math.max(sheet.getLastColumn(), headers.length);
  var firstRow = sheet.getRange(1, 1, 1, headerWidth).getValues()[0];
  var map = columnMap_(firstRow);
  if (map.Email === undefined || map.Password_Record === undefined || map.Display_Name === undefined || map.Role === undefined || map.Active === undefined || map.Created_At === undefined || map.Last_Login === undefined) {
    ensureHeaders_(sheet, headers);
    firstRow = sheet.getRange(1, 1, 1, Math.max(sheet.getLastColumn(), headers.length)).getValues()[0];
    map = columnMap_(firstRow);
  }
  if (map.Email === undefined || map.Password_Record === undefined || map.Display_Name === undefined || map.Role === undefined || map.Active === undefined) {
    throw new Error('Users sheet headers are invalid. Expected: ' + headers.join(', '));
  }

  var lastRow = sheet.getLastRow();
  var values = lastRow > 1 ? sheet.getRange(2, 1, lastRow - 1, headerWidth).getValues() : [];
  var indexes = columnMap_(headers);
  var record = makePasswordRecord_(password);
  for (var i = 0; i < values.length; i++) {
    if (normalizeEmail_(values[i][indexes.Email]) === email) {
      var rowIndex = i + 2;
      sheet.getRange(rowIndex, indexes.Password_Record + 1).setValue(record);
      sheet.getRange(rowIndex, indexes.Display_Name + 1).setValue(displayName);
      sheet.getRange(rowIndex, indexes.Role + 1).setValue(role);
      sheet.getRange(rowIndex, indexes.Active + 1).setValue('TRUE');
      SpreadsheetApp.flush();
      return 'Updated user ' + email;
    }
  }

  var row = headers.map(function (header) {
    var data = {
      Email: email,
      Password_Record: record,
      Display_Name: displayName,
      Role: role,
      Active: 'TRUE',
      Created_At: formatDateTime_(new Date()),
      Last_Login: ''
    };
    return data[header] !== undefined ? data[header] : '';
  });
  sheet.getRange(lastRow + 1, 1, 1, headers.length).setValues([row]);
  SpreadsheetApp.flush();
  return 'Created user ' + email;
}

function createAdminUser(email, password, displayName) {
  return seedUser(email, password, displayName || email, 'admin');
}

function seedAdminUser() {
  var email = 'admin@ched.gov.ph';
  var password = 'change-this-password';
  var displayName = 'Admin User';

  if (email === 'admin@ched.gov.ph' || password === 'change-this-password') {
    throw new Error('Edit seedAdminUser() with a real admin email and password before running it.');
  }

  return seedUser(email, password, displayName, 'admin');
}

function setUserPassword(email, password) {
  return seedUser(email, password, '', 'admin');
}

function setupProject_() {
  getSubmissionsSheet_(getConfig_());
  getUsersSheet_();
  getAuditSheet_();
  getSessionSecret_();
  return 'TOSF backend setup complete.';
}

function verifySubmitToken_(token) {
  var expected = String(getProps_().SUBMIT_SHARED_TOKEN || '');
  if (expected && !constantTimeEquals_(String(token || ''), expected)) throw new Error('Invalid submit token.');
}

function auditLog_(action, status, reference, email, detail) {
  try {
    getAuditSheet_().appendRow([formatDateTime_(new Date()), action, status, reference || '', email || '', detail || '']);
  } catch (err) {}
}

// Per-execution caches. Each web-app request runs in a fresh context, so these
// only deduplicate work within a single request (config was previously fetched
// property-by-property several times per request, and the spreadsheet was
// reopened for every sheet access).
var CONFIG_CACHE_ = null;
var PROPS_CACHE_ = null;
var SPREADSHEET_CACHE_ = null;

function getProps_() {
  if (!PROPS_CACHE_) PROPS_CACHE_ = PropertiesService.getScriptProperties().getProperties();
  return PROPS_CACHE_;
}

function getConfig_() {
  if (CONFIG_CACHE_) return CONFIG_CACHE_;
  var props = getProps_();
  CONFIG_CACHE_ = {
    spreadsheetId: props.SPREADSHEET_ID || '',
    submissionsSheetName: props.SUBMISSIONS_SHEET_NAME || 'TOSF_Submissions',
    usersSheetName: props.USERS_SHEET_NAME || 'Users',
    auditSheetName: props.AUDIT_SHEET_NAME || 'Audit',
    heiListSheetName: props.HEI_LIST_SHEET_NAME || 'HEI_List',
    portalOpen: String(props.PORTAL_OPEN || 'TRUE').toUpperCase() !== 'FALSE',
    allowedEmailDomain: cleanText_(props.ALLOWED_EMAIL_DOMAIN || '', 100).toLowerCase()
  };
  return CONFIG_CACHE_;
}

/**
 * Verifies that an email was recently confirmed through the one-time passcode
 * flow. Returns { email } on success or throws.
 */
function verifyOtpSessionToken_(token, config) {
  config = config || getConfig_();
  token = cleanText_(token, 160);
  if (!token) throw new Error('Email verification is required.');

  var raw = CacheService.getScriptCache().get('otp_session_' + token);
  if (!raw) throw new Error('Email verification expired. Please verify your email again.');

  var session;
  try {
    session = JSON.parse(raw);
  } catch (err) {
    throw new Error('Email verification expired. Please verify your email again.');
  }

  var email = normalizeEmail_(session.email);
  if (!email) throw new Error('Email verification expired. Please verify your email again.');
  if (Number(session.exp || 0) < Math.floor(Date.now() / 1000)) throw new Error('Email verification expired. Please verify your email again.');
  enforceAllowedDomain_(email, config);

  return { email: email };
}

function enforceAllowedDomain_(email, config) {
  config = config || getConfig_();
  email = normalizeEmail_(email);
  if (!email) throw new Error('Enter a valid official email address.');
  var domain = String(email.split('@')[1] || '').toLowerCase();
  if (config.allowedEmailDomain && domain !== config.allowedEmailDomain) throw new Error('Please use your @' + config.allowedEmailDomain + ' email address.');
}

function hashKey_(value) {
  var bytes = Utilities.computeHmacSha256Signature(String(value || ''), getSessionSecret_());
  return base64UrlEncodeBytes_(bytes);
}

function randomDigits_(length) {
  var out = '';
  for (var i = 0; i < length; i++) out += String(Math.floor(Math.random() * 10));
  return out;
}

function openSpreadsheet_(config) {
  if (SPREADSHEET_CACHE_) return SPREADSHEET_CACHE_;
  config = config || getConfig_();
  if (!config.spreadsheetId) throw new Error('Missing SPREADSHEET_ID script property.');
  SPREADSHEET_CACHE_ = SpreadsheetApp.openById(config.spreadsheetId);
  return SPREADSHEET_CACHE_;
}

function formatDateTime_(value) {
  if (!value) return '';
  var date = value instanceof Date ? value : new Date(value);
  if (isNaN(date.getTime())) return String(value || '');
  return Utilities.formatDate(date, APP_TIME_ZONE, 'yyyy-MM-dd HH:mm:ss');
}

function columnMap_(headers) {
  var map = {};
  headers.forEach(function (header, index) {
    map[normalizeHeader_(header)] = index;
  });
  return map;
}

function normalizeHeader_(value) {
  return String(value || '').trim().replace(/^\uFEFF/, '').replace(/[^A-Za-z0-9]+/g, '_').replace(/^_+|_+$/g, '');
}

function rowToObject_(headers, row) {
  var obj = {};
  headers.forEach(function (header, index) {
    obj[normalizeHeader_(header)] = row[index];
  });
  return obj;
}

function cleanText_(value, maxLen) {
  var text = String(value === null || value === undefined ? '' : value).replace(/\s+/g, ' ').trim();
  if (maxLen && text.length > maxLen) text = text.slice(0, maxLen);
  return text;
}

function normalizeEmail_(value) {
  var email = cleanText_(value, 254).toLowerCase();
  return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email) ? email : '';
}

function normalizeKey_(value) {
  return cleanText_(value, 500).toLowerCase().replace(/[^a-z0-9]+/g, ' ').replace(/\s+/g, ' ').trim();
}

function isTruthyFlag_(value) {
  var text = String(value || '').trim().toLowerCase();
  return ['true', 'yes', 'y', '1', 'active'].indexOf(text) !== -1;
}

function constantTimeEquals_(a, b) {
  a = String(a || '');
  b = String(b || '');
  var len = Math.max(a.length, b.length);
  var result = a.length === b.length ? 0 : 1;
  for (var i = 0; i < len; i++) {
    result |= (a.charCodeAt(i) || 0) ^ (b.charCodeAt(i) || 0);
  }
  return result === 0;
}

function bytesToBase64_(bytes) {
  return Utilities.base64Encode(bytes);
}

function base64UrlEncode_(text) {
  return base64UrlEncodeBytes_(Utilities.newBlob(String(text)).getBytes());
}

function base64UrlEncodeBytes_(bytes) {
  return Utilities.base64EncodeWebSafe(bytes).replace(/=+$/g, '');
}

function base64UrlDecode_(value) {
  var padded = String(value || '');
  while (padded.length % 4) padded += '=';
  return Utilities.newBlob(Utilities.base64DecodeWebSafe(padded)).getDataAsString();
}

function errorMessage_(err) {
  return (err && err.message) ? err.message : String(err || 'Unknown error');
}

function jsonOutput_(obj) {
  return ContentService.createTextOutput(JSON.stringify(obj)).setMimeType(ContentService.MimeType.JSON);
}
