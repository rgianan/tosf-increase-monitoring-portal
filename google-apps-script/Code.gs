/**
 * TOSF Increase Monitoring backend for Google Apps Script.
 *
 * Script Properties:
 * - SPREADSHEET_ID              required
 * - SUBMISSIONS_SHEET_NAME      optional, default: TOSF_Submissions
 * - USERS_SHEET_NAME            optional, default: Users
 * - AUDIT_SHEET_NAME            optional, default: Audit
 * - HEI_LIST_SHEET_NAME         optional, default: HEI_List. Optional but recommended for server-side HEI validation.
 * - SUBMIT_SHARED_TOKEN         optional. If set, frontend must send the same submitToken.
 * - PORTAL_OPEN                 optional TRUE/FALSE. Defaults TRUE.
 * - ALLOWED_EMAIL_DOMAIN        optional email domain restriction, e.g. ched.gov.ph.
 * - SESSION_SECRET              optional. Auto-generated by setupProject_() or first login if missing.
 * - PASSWORD_PEPPER             optional. Auto-generated; keys v3 password records. Changing it invalidates all passwords (re-seed users).
 *
 * Admin accounts:
 * Run seedUser('admin@ched.gov.ph', 'strong-password', 'Admin Name', 'admin') in the Apps Script editor.
 */

var APP_TIME_ZONE = 'Asia/Singapore';
var SESSION_TTL_SECONDS = 12 * 60 * 60;
var OTP_TTL_SECONDS = 10 * 60;
var OTP_SESSION_TTL_SECONDS = 2 * 60 * 60;
var OTP_REQUEST_COOLDOWN_SECONDS = 60;
var OTP_MAX_ATTEMPTS = 5;
var SUBMISSION_ID_PREFIX = 'TOSF';

