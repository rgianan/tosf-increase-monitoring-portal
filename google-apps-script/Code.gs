var ACTION_STATUS_OPTIONS = [
  'CHEDRO Approved',
  'CHEDRO Denied',
  'HEI agreed to defer implementation',
  'HEI will proceed with AY 2026-2027',
  'Decrease: within RIR',
  'Decrease: from above RIR to within RIR',
  'Application below the RIR is decreased',
  'Under consideration, pending final decision',
  'No response from HEI',
  'Others'
];

var RIR_CATEGORY_OPTIONS = [
  'Below the applicable RIR',
  'Equivalent to the applicable RIR',
  'Higher than the RIR'
];

function doGet(e) {
  return jsonOutput_({ ok: true, message: 'TOSF Increase Monitoring backend is running.', mode: 'tosf_monitoring' });
}

function doPost(e) {
  try {
    var payload = JSON.parse((e && e.postData && e.postData.contents) || '{}');
    var action = cleanText_(payload.action, 80);

    if (action === 'getFormOptions') return handleGetFormOptions_(payload);
    if (action === 'requestEmailOtp') return handleRequestEmailOtp_(payload);
    if (action === 'verifyEmailOtp') return handleVerifyEmailOtp_(payload);
    if (action === 'submitTosf') return handleSubmitTosf_(payload);
    if (action === 'listMySubmissions') return handleListMySubmissions_(payload);
    if (action === 'updateMySubmission') return handleUpdateMySubmission_(payload);
    if (action === 'voidMySubmission') return handleVoidMySubmission_(payload);
    if (action === 'adminLogin') return handleAdminLogin_(payload);
    if (action === 'listTosfSubmissions') return handleListTosfSubmissions_(payload);
    if (action === 'setPortalStatus') return handleSetPortalStatus_(payload);

    throw new Error('Unsupported action.');
  } catch (err) {
    return jsonOutput_({ ok: false, message: errorMessage_(err) });
  }
}

function handleGetFormOptions_(payload) {
  return jsonOutput_({
    ok: true,
    portalOpen: getConfig_().portalOpen,
    regions: REGION_META,
    actionStatusOptions: ACTION_STATUS_OPTIONS,
    rirCategoryOptions: RIR_CATEGORY_OPTIONS
  });
}

function handleRequestEmailOtp_(payload) {
  payload = payload || {};
  var config = getConfig_();
  var email = normalizeEmail_(payload.email);
  if (!email) throw new Error('Enter a valid official email address.');
  enforceAllowedDomain_(email, config);

  var cache = CacheService.getScriptCache();
  var cooldownKey = 'otp_cd_' + hashKey_(email);
  if (cache.get(cooldownKey)) throw new Error('Please wait a minute before requesting another code.');

  var requestId = Utilities.getUuid();
  var code = randomDigits_(6);
  var record = {
    email: email,
    codeHash: sign_(requestId + ':' + email + ':' + code),
    attempts: 0,
    exp: Math.floor(Date.now() / 1000) + OTP_TTL_SECONDS
  };

  cache.put('otp_' + requestId, JSON.stringify(record), OTP_TTL_SECONDS);
  cache.put(cooldownKey, '1', OTP_REQUEST_COOLDOWN_SECONDS);

  MailApp.sendEmail({
    to: email,
    subject: 'TOSF monitoring verification code',
    body: [
      'Your TOSF Increase Monitoring verification code is:',
      '',
      code,
      '',
      'This code expires in 10 minutes. If you did not request this code, you may ignore this email.'
    ].join('\n')
  });

  auditLog_('email_otp_requested', 'ok', '', email, 'OTP sent.');
  return jsonOutput_({
    ok: true,
    otpRequestId: requestId,
    message: 'Verification code sent to ' + email + '.'
  });
}

function handleVerifyEmailOtp_(payload) {
  payload = payload || {};
  var config = getConfig_();
  var requestId = cleanText_(payload.otpRequestId, 80);
  var code = String(payload.otpCode || '').replace(/\D/g, '');
  if (!requestId || !code) throw new Error('Enter the verification code sent to your email.');
  if (code.length !== 6) throw new Error('The verification code must be 6 digits.');

  var cache = CacheService.getScriptCache();
  var cacheKey = 'otp_' + requestId;
  var raw = cache.get(cacheKey);
  if (!raw) throw new Error('Verification code expired. Request a new code.');

  var record;
  try {
    record = JSON.parse(raw);
  } catch (err) {
    throw new Error('Verification code expired. Request a new code.');
  }

  if (!record.email) throw new Error('Verification code expired. Request a new code.');
  enforceAllowedDomain_(record.email, config);
  if (Number(record.exp || 0) < Math.floor(Date.now() / 1000)) {
    cache.remove(cacheKey);
    throw new Error('Verification code expired. Request a new code.');
  }
  if (Number(record.attempts || 0) >= OTP_MAX_ATTEMPTS) {
    cache.remove(cacheKey);
    throw new Error('Too many incorrect attempts. Request a new code.');
  }

  var expected = sign_(requestId + ':' + record.email + ':' + code);
  if (!constantTimeEquals_(expected, record.codeHash)) {
    record.attempts = Number(record.attempts || 0) + 1;
    var ttl = Math.max(1, Number(record.exp || 0) - Math.floor(Date.now() / 1000));
    cache.put(cacheKey, JSON.stringify(record), ttl);
    throw new Error('Invalid verification code.');
  }

  cache.remove(cacheKey);
  var sessionToken = Utilities.getUuid() + '-' + randomString_(24);
  cache.put('otp_session_' + sessionToken, JSON.stringify({
    email: record.email,
    exp: Math.floor(Date.now() / 1000) + OTP_SESSION_TTL_SECONDS
  }), OTP_SESSION_TTL_SECONDS);

  auditLog_('email_otp_verified', 'ok', '', record.email, 'OTP verified.');
  return jsonOutput_({
    ok: true,
    email: record.email,
    otpSessionToken: sessionToken,
    message: 'Email verified.'
  });
}

function handleSubmitTosf_(payload) {
  payload = payload || {};
  var config = getConfig_();
  if (!config.portalOpen) throw new Error('The TOSF monitoring portal is currently closed.');
  verifySubmitToken_(payload.submitToken);
  if (cleanText_(payload.website, 200)) throw new Error('Submission rejected.');

  // Authorize the submission with a verified email OTP session and trust the
  // verified email over anything the client sent.
  var otpUser = verifyOtpSessionToken_(payload.otpSessionToken, config);
  payload.submittedByEmail = otpUser.email;

  var rows = sanitizeSubmissionRows_(payload);
  var lock = LockService.getDocumentLock();
  lock.waitLock(20000);

  try {
    var sheet = getSubmissionsSheet_(config);
    var headers = getSubmissionHeaders_();
    var timestamp = new Date();
    var existingIds = readSubmissionIdSet_(sheet);
    var submissionIds = [];
    var values = [];

    rows.forEach(function (row) {
      var submissionId = makeUniqueSubmissionIdFromSet_(existingIds);
      submissionIds.push(submissionId);
      values.push(submissionToRow_(headers, {
        timestamp: timestamp,
        submissionId: submissionId,
        row: row,
        updatedAt: timestamp,
        updatedBy: row.submittedByEmail || 'public_form',
        userAgent: cleanText_(payload.userAgent, 500),
        clientOrigin: cleanText_(payload.clientOrigin, 200)
      }));
    });

    sheet.getRange(sheet.getLastRow() + 1, 1, values.length, headers.length).setValues(values);
    invalidateSubmissionsCache_();
    auditLog_('tosf_submission_created', 'ok', submissionIds.join(', '), rows[0].submittedByEmail, rows[0].regionLabel + ' / ' + rows.length + ' HEI(s)');

    return jsonOutput_({
      ok: true,
      submissionId: submissionIds[0] || '',
      submissionIds: submissionIds,
      message: rows.length === 1 ? 'TOSF monitoring submission recorded.' : rows.length + ' TOSF monitoring entries recorded.'
    });
  } finally {
    lock.releaseLock();
  }
}

function sanitizeSubmissionRows_(payload) {
  var regionCode = normalizeRegionCode_(payload.regionCode);
  var region = getRegionByCode_(regionCode);
  if (!region) throw new Error('Invalid CHED Regional Office.');

  var submittedByName = cleanText_(payload.submittedByName, 180);
  var submittedByEmail = normalizeEmail_(payload.submittedByEmail);
  if (!submittedByName) throw new Error('Submitted by name is required.');
  if (!submittedByEmail) throw new Error('Official email address is required.');

  var rawEntries = Array.isArray(payload.entries) && payload.entries.length ? payload.entries : [payload];
  if (rawEntries.length > 200) throw new Error('A maximum of 200 HEIs may be submitted at once.');

  var common = {
    regionCode: region.code,
    regionLabel: region.label,
    rir: region.rir,
    submittedByName: submittedByName,
    submittedByEmail: submittedByEmail,
    submittedByPosition: cleanText_(payload.submittedByPosition, 250),
    submittedByContact: cleanText_(payload.submittedByContact, 100)
  };

  var seen = {};
  return rawEntries.map(function (entry) {
    var row = sanitizeSubmissionEntry_(entry || {}, common);
    var key = normalizeKey_(row.uii || row.heiName);
    if (seen[key]) throw new Error('Duplicate HEI in submission: ' + row.heiName + '.');
    seen[key] = true;
    return row;
  });
}

function sanitizeSubmissionEntry_(entry, common) {
  var hei = sanitizeHei_(entry.hei || {}, common.regionCode);
  var proposedTfIncrease = nullableNumber_(entry.proposedTfIncrease, 'Proposed TF Increase');
  var proposedOsfIncrease = nullableNumber_(entry.proposedOsfIncrease, 'Proposed OSF Increase');
  if (proposedTfIncrease === null && proposedOsfIncrease === null) throw new Error('At least one proposed increase field is required for ' + hei.name + '.');
  if (proposedTfIncrease !== null && proposedTfIncrease < 0) throw new Error('Proposed TF Increase cannot be negative for ' + hei.name + '.');
  if (proposedOsfIncrease !== null && proposedOsfIncrease < 0) throw new Error('Proposed OSF Increase cannot be negative for ' + hei.name + '.');

  var computedCategory = computeRirCategory_(proposedTfIncrease, proposedOsfIncrease, common.rir);
  var clientCategory = cleanText_(entry.rirCategory, 80);
  if (clientCategory && clientCategory !== computedCategory) {
    throw new Error('RIR category mismatch for ' + hei.name + '. Refresh the form and try again.');
  }

  var actionStatus = cleanText_(entry.actionStatus, 120);
  if (ACTION_STATUS_OPTIONS.indexOf(actionStatus) === -1) throw new Error('Invalid action/status for ' + hei.name + '.');

  var otherSpecifics = cleanText_(entry.otherSpecifics, 1000);
  if (actionStatus === 'Others' && !otherSpecifics) throw new Error('Please indicate specifics when action/status is Others for ' + hei.name + '.');
  if (actionStatus !== 'Others') otherSpecifics = '';

  return {
    regionCode: common.regionCode,
    regionLabel: common.regionLabel,
    rir: common.rir,
    uii: hei.uii,
    heiName: hei.name,
    province: hei.province,
    cityMunicipality: hei.cityMunicipality,
    heiStatus: hei.status,
    proposedTfIncrease: proposedTfIncrease,
    proposedOsfIncrease: proposedOsfIncrease,
    rirCategory: computedCategory,
    actionStatus: actionStatus,
    otherSpecifics: otherSpecifics,
    remarks: cleanText_(entry.remarks, 2500),
    submittedByName: common.submittedByName,
    submittedByEmail: common.submittedByEmail,
    submittedByPosition: common.submittedByPosition,
    submittedByContact: common.submittedByContact
  };
}

function sanitizeHei_(rawHei, expectedRegionCode) {
  var input = {
    name: cleanText_(rawHei.name || rawHei['HEI Name'], 350),
    uii: cleanText_(rawHei.uii || rawHei.UII, 50),
    regionCode: normalizeRegionCode_(rawHei.regionCode || rawHei.Region),
    province: cleanText_(rawHei.province || rawHei.Province, 180),
    cityMunicipality: cleanText_(rawHei.cityMunicipality || rawHei['City/Municipality'], 180),
    status: cleanText_(rawHei.status || rawHei.Status, 80)
  };

  if (!input.name) throw new Error('HEI is required.');
  if (input.regionCode && input.regionCode !== expectedRegionCode) throw new Error('Selected HEI does not belong to the selected region.');

  var masterHei = findHeiFromMaster_(input.uii, input.name, expectedRegionCode);
  if (masterHei) {
    // TOSF monitoring covers private HEIs only (HEI Type 1 in the masterlist).
    // Skip the check when the sheet has no HEI Type column (older masterlists).
    if (masterHei.heiType && masterHei.heiType !== '1') {
      throw new Error('Only private HEIs are covered by TOSF increase monitoring: ' + masterHei.name + '.');
    }
    return masterHei;
  }

  // Fallback permits development or emergency deployment before the HEI_List
  // sheet is seeded, but still enforces the region selected by the frontend CSV.
  if (!input.uii) throw new Error('Selected HEI must include UII.');
  return input;
}

function findHeiFromMaster_(uii, heiName, expectedRegionCode) {
  var config = getConfig_();
  var ss = openSpreadsheet_(config);
  var sheet = ss.getSheetByName(config.heiListSheetName);
  if (!sheet || sheet.getLastRow() < 2) return null;

  var values = sheet.getDataRange().getValues();
  var headers = values[0];
  var map = columnMap_(headers);
  var targetUii = cleanText_(uii, 50).toLowerCase();
  var targetName = normalizeKey_(heiName);

  for (var i = 1; i < values.length; i++) {
    var row = values[i];
    var rowRegion = normalizeRegionCode_(row[map.Region]);
    if (rowRegion !== expectedRegionCode) continue;

    var rowUii = cleanText_(row[map.UII], 50).toLowerCase();
    var rowName = cleanText_(row[map.HEI_Name], 350);
    var nameMatches = targetName && normalizeKey_(rowName) === targetName;
    var uiiMatches = targetUii && rowUii === targetUii;

    if (uiiMatches || nameMatches) {
      return {
        name: rowName,
        uii: cleanText_(row[map.UII], 50),
        regionCode: rowRegion,
        heiType: map.HEI_Type === undefined ? '' : cleanText_(row[map.HEI_Type], 20),
        province: cleanText_(row[map.Province], 180),
        cityMunicipality: cleanText_(row[map.City_Municipality], 180),
        status: cleanText_(row[map.Status], 80)
      };
    }
  }
  return null;
}

// ---- Submitter self-service (OTP-verified, own rows only) ----

function handleListMySubmissions_(payload) {
  payload = payload || {};
  var config = getConfig_();
  var otpUser = verifyOtpSessionToken_(payload.otpSessionToken, config);
  var email = otpUser.email;

  var sheet = getSubmissionsSheet_(config);
  var values = sheet.getDataRange().getValues();
  if (!values || values.length < 2) return jsonOutput_({ ok: true, rows: [], email: email });

  var headers = values[0];
  var rows = [];
  for (var i = 1; i < values.length; i++) {
    var obj = rowToObject_(headers, values[i]);
    if (normalizeEmail_(obj.Submitted_By_Email) !== email) continue;
    if (isTruthyFlag_(obj.Voided)) continue;
    rows.push(submissionObjectToPayload_(obj));
  }
  rows.sort(function (a, b) { return String(b.timestamp).localeCompare(String(a.timestamp)); });
  return jsonOutput_({ ok: true, rows: rows, email: email });
}

function handleUpdateMySubmission_(payload) {
  payload = payload || {};
  var config = getConfig_();
  var otpUser = verifyOtpSessionToken_(payload.otpSessionToken, config);
  var email = otpUser.email;
  var submissionId = cleanText_(payload.submissionId, 80);
  if (!submissionId) throw new Error('Missing submission reference.');

  var lock = LockService.getDocumentLock();
  lock.waitLock(20000);
  try {
    var sheet = getSubmissionsSheet_(config);
    var located = locateSubmissionRow_(sheet, submissionId);
    if (!located) throw new Error('Submission not found.');
    if (normalizeEmail_(located.obj.Submitted_By_Email) !== email) throw new Error('You can only edit your own submissions.');
    if (isTruthyFlag_(located.obj.Voided)) throw new Error('This submission was deleted and can no longer be edited.');

    var proposedTf = nullableNumber_(payload.proposedTfIncrease, 'Proposed TF Increase');
    var proposedOsf = nullableNumber_(payload.proposedOsfIncrease, 'Proposed OSF Increase');
    if (proposedTf === null && proposedOsf === null) throw new Error('At least one proposed increase is required.');
    if (proposedTf !== null && proposedTf < 0) throw new Error('Proposed TF Increase cannot be negative.');
    if (proposedOsf !== null && proposedOsf < 0) throw new Error('Proposed OSF Increase cannot be negative.');

    var actionStatus = cleanText_(payload.actionStatus, 120);
    if (ACTION_STATUS_OPTIONS.indexOf(actionStatus) === -1) throw new Error('Invalid action/status.');
    var otherSpecifics = cleanText_(payload.otherSpecifics, 1000);
    if (actionStatus === 'Others' && !otherSpecifics) throw new Error('Please indicate specifics when action/status is Others.');
    if (actionStatus !== 'Others') otherSpecifics = '';
    var remarks = cleanText_(payload.remarks, 2500);

    var rirCategory = computeRirCategory_(proposedTf, proposedOsf, numberOrNull_(located.obj.RIR));

    var now = formatDateTime_(new Date());
    setCell_(sheet, located, 'Proposed_TF_Increase', proposedTf === null ? '' : proposedTf);
    setCell_(sheet, located, 'Proposed_OSF_Increase', proposedOsf === null ? '' : proposedOsf);
    setCell_(sheet, located, 'RIR_Category', rirCategory);
    setCell_(sheet, located, 'Action_Status', actionStatus);
    setCell_(sheet, located, 'Other_Specifics', otherSpecifics);
    setCell_(sheet, located, 'Remarks', remarks);
    setCell_(sheet, located, 'Updated_At', now);
    setCell_(sheet, located, 'Updated_By', email);

    invalidateSubmissionsCache_();
    auditLog_('submission_updated', 'ok', submissionId, email, 'Self-service edit.');
    return jsonOutput_({ ok: true, message: 'Submission updated.', submissionId: submissionId, rirCategory: rirCategory });
  } finally {
    lock.releaseLock();
  }
}

function handleVoidMySubmission_(payload) {
  payload = payload || {};
  var config = getConfig_();
  var otpUser = verifyOtpSessionToken_(payload.otpSessionToken, config);
  var email = otpUser.email;
  var submissionId = cleanText_(payload.submissionId, 80);
  if (!submissionId) throw new Error('Missing submission reference.');

  var lock = LockService.getDocumentLock();
  lock.waitLock(20000);
  try {
    var sheet = getSubmissionsSheet_(config);
    var located = locateSubmissionRow_(sheet, submissionId);
    if (!located) throw new Error('Submission not found.');
    if (normalizeEmail_(located.obj.Submitted_By_Email) !== email) throw new Error('You can only delete your own submissions.');
    if (isTruthyFlag_(located.obj.Voided)) return jsonOutput_({ ok: true, message: 'Submission already deleted.', submissionId: submissionId });

    var now = formatDateTime_(new Date());
    setCell_(sheet, located, 'Voided', 'TRUE');
    setCell_(sheet, located, 'Voided_At', now);
    setCell_(sheet, located, 'Updated_At', now);
    setCell_(sheet, located, 'Updated_By', email);

    invalidateSubmissionsCache_();
    auditLog_('submission_voided', 'ok', submissionId, email, 'Self-service delete (soft).');
    return jsonOutput_({ ok: true, message: 'Submission deleted.', submissionId: submissionId });
  } finally {
    lock.releaseLock();
  }
}

// Finds a submission row by ID. Returns { rowIndex (1-based), map, obj } or null.
function locateSubmissionRow_(sheet, submissionId) {
  var values = sheet.getDataRange().getValues();
  if (!values || values.length < 2) return null;
  var headers = values[0];
  var map = columnMap_(headers);
  if (map.Submission_ID === undefined) return null;
  var target = cleanText_(submissionId, 80);
  for (var i = 1; i < values.length; i++) {
    if (cleanText_(values[i][map.Submission_ID], 80) === target) {
      return { rowIndex: i + 1, map: map, obj: rowToObject_(headers, values[i]) };
    }
  }
  return null;
}

function setCell_(sheet, located, headerKey, value) {
  var col = located.map[headerKey];
  if (col === undefined) return;
  sheet.getRange(located.rowIndex, col + 1).setValue(value);
}

function handleAdminLogin_(payload) {
  payload = payload || {};
  var email = normalizeEmail_(payload.email);
  var password = String(payload.password || '');
  if (!email || !password) throw new Error('Email and password are required.');

  var found = findUserRecord_(email);
  var user = found && found.user;
  if (!user || !isTruthyFlag_(user.Active)) throw new Error('Invalid admin credentials.');
  var record = String(user.Password_Record || '');
  if (!verifyPassword_(password, record)) throw new Error('Invalid admin credentials.');

  // Transparently migrate slow legacy v1/v2 records to the instant v3 format
  // using the password that just verified, so old accounts speed up on their
  // next login without a manual re-seed.
  if (isLegacyPasswordRecord_(record) && found.map.Password_Record !== undefined) {
    found.sheet.getRange(found.rowIndex, found.map.Password_Record + 1).setValue(makePasswordRecord_(password));
  }

  var token = issueAdminToken_(user);
  if (found.map.Last_Login !== undefined) {
    found.sheet.getRange(found.rowIndex, found.map.Last_Login + 1).setValue(formatDateTime_(new Date()));
  }
  auditLog_('admin_login', 'ok', '', email, 'Password admin login.');

  return jsonOutput_({
    ok: true,
    token: token,
    email: email,
    displayName: String(user.Display_Name || email),
    role: String(user.Role || 'admin')
  });
}

// Full-sheet scan + rebuild is expensive and was previously run from scratch
// on every admin load. Under concurrent traffic (several admins refreshing,
// or writers holding the document lock) that means every request re-pays the
// full cost and competes for Apps Script's shared simultaneous-execution
// quota. Cache the processed { rows, summary } for a short TTL so concurrent
// or repeated loads are served without touching the Sheets API at all;
// writes proactively invalidate it so admins still see fresh data promptly.
var SUBMISSIONS_CACHE_KEY_ = 'tosf_submissions_list_v1';
var SUBMISSIONS_CACHE_TTL_SECONDS_ = 30;

function handleListTosfSubmissions_(payload) {
  requireAdmin_(payload);
  var config = getConfig_();
  var cached = readSubmissionsCache_();
  if (cached) return jsonOutput_({ ok: true, rows: cached.rows, portalOpen: config.portalOpen, summary: cached.summary });

  var sheet = getSubmissionsSheet_(config);
  var values = sheet.getDataRange().getValues();
  if (!values || values.length < 2) {
    writeSubmissionsCache_([], buildSummary_([]));
    return jsonOutput_({ ok: true, rows: [], portalOpen: config.portalOpen, summary: buildSummary_([]) });
  }

  var headers = values[0];
  var rows = [];
  for (var i = 1; i < values.length; i++) {
    var obj = rowToObject_(headers, values[i]);
    if (isTruthyFlag_(obj.Voided)) continue; // soft-deleted rows are excluded from counts
    rows.push(submissionObjectToPayload_(obj));
  }

  rows.sort(function (a, b) { return String(b.timestamp).localeCompare(String(a.timestamp)); });
  var summary = buildSummary_(rows);
  writeSubmissionsCache_(rows, summary);
  return jsonOutput_({ ok: true, rows: rows, portalOpen: config.portalOpen, summary: summary });
}

function readSubmissionsCache_() {
  try {
    var raw = CacheService.getScriptCache().get(SUBMISSIONS_CACHE_KEY_);
    return raw ? JSON.parse(raw) : null;
  } catch (err) {
    return null;
  }
}

function writeSubmissionsCache_(rows, summary) {
  try {
    var payload = JSON.stringify({ rows: rows, summary: summary });
    // CacheService values are capped at 100KB; skip caching rather than error
    // once the dataset outgrows that (the list still works, just uncached).
    if (payload.length < 95000) CacheService.getScriptCache().put(SUBMISSIONS_CACHE_KEY_, payload, SUBMISSIONS_CACHE_TTL_SECONDS_);
  } catch (err) {
    // Best-effort: caching is a speed optimization, never a correctness requirement.
  }
}

function invalidateSubmissionsCache_() {
  try {
    CacheService.getScriptCache().remove(SUBMISSIONS_CACHE_KEY_);
  } catch (err) {}
}

function handleSetPortalStatus_(payload) {
  var session = requireAdmin_(payload);
  var open = !!payload.open;
  PropertiesService.getScriptProperties().setProperty('PORTAL_OPEN', open ? 'TRUE' : 'FALSE');
  auditLog_('portal_status_changed', 'ok', '', session.email, 'portalOpen=' + open);
  return jsonOutput_({ ok: true, portalOpen: open, message: 'Portal is now ' + (open ? 'open' : 'closed') + '.' });
}

